# Define minimum iOS version required by modern Flutter plugins.
platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  # Static framework linkage is more compatible in Flutter plugin graphs.
  use_frameworks! :linkage => :static

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end

  # rive_native (rive >= 0.14) ships prebuilt static engine libs and force-loads
  # them via its pod_target_xcconfig. Under `use_frameworks! :linkage => :static`
  # those pod-level link flags do NOT reach the Runner app target, so rive's
  # symbols (_createRiveRenderer, _riveFontDummyLinker, ReadWriteRing, ...) end up
  # undefined at the final link. Re-apply rive_native's force-load + library search
  # path on Runner (sdk-conditional so device and simulator both link). Only when
  # rive is actually in the build, so non-rive apps are unaffected.
  apply_rive_native_linking(installer)
end

# Adds rive_native's prebuilt-lib force-load to the Pods-Runner xcconfigs so the
# rive engine links into the app under static-framework linkage.
def apply_rive_native_linking(installer)
  return unless installer.pods_project.targets.any? { |t| t.name == 'rive_native' }

  rive_libs = %w[
    rive rive_pls_renderer rive_yoga rive_harfbuzz rive_sheenbidi rive_decoders
    libpng zlib libjpeg libwebp miniaudio luau_vm luau_compiler luau_analyzer
    rive_scripting_workspace spirv_cross brotli
  ]
  rive_ldflags = " -Wl,-force_load,${RIVE_NATIVE_LIB_DIR}/librive_native.a " +
                 rive_libs.map { |lib| "-l#{lib}" }.join(' ')
  base = '${PODS_ROOT}/../.symlinks/plugins/rive_native/native/build/iphoneos/bin'

  Dir.glob(File.join(installer.sandbox.root, 'Target Support Files', 'Pods-Runner', 'Pods-Runner.*.xcconfig')).each do |xcconfig|
    contents = File.read(xcconfig)
    next if contents.include?('RIVE_NATIVE_LIB_DIR')

    if contents =~ /^OTHER_LDFLAGS = .*$/
      contents = contents.sub(/^OTHER_LDFLAGS = (.*)$/) { "OTHER_LDFLAGS = #{Regexp.last_match(1)}#{rive_ldflags}" }
    else
      contents += "OTHER_LDFLAGS = $(inherited)#{rive_ldflags}\n"
    end

    if contents =~ /^LIBRARY_SEARCH_PATHS = .*$/
      contents = contents.sub(/^LIBRARY_SEARCH_PATHS = (.*)$/) { "LIBRARY_SEARCH_PATHS = #{Regexp.last_match(1)} \"${RIVE_NATIVE_LIB_DIR}\"" }
    else
      contents += "LIBRARY_SEARCH_PATHS = $(inherited) \"${RIVE_NATIVE_LIB_DIR}\"\n"
    end

    contents += "RIVE_NATIVE_LIB_DIR[sdk=iphoneos*] = #{base}/release\n"
    contents += "RIVE_NATIVE_LIB_DIR[sdk=iphonesimulator*] = #{base}/emulator\n"
    File.write(xcconfig, contents)
  end
end
